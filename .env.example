# ============================================================
# .env.example — West Point Travel System
# ============================================================
#
# This file shows what environment variables the system needs.
# It is safe to commit to version control because it has no
# real secrets — it's just a template showing the variable names.
#
# HOW TO USE:
#   1. Make a copy of this file named exactly ".env"
#      Windows:   copy .env.example .env
#      Mac/Linux: cp .env.example .env
#
#   2. Open .env and replace "your_key_here" with your real key.
#
#   3. NEVER commit your .env file to git — it contains your secret key.
#      It is already listed in .gitignore to protect you automatically.
#
# ============================================================


# ------------------------------------------------------------
# SERPAPI_KEY
# ------------------------------------------------------------
# Your SerpAPI API key. Used by flights.py to fetch real
# flight data from Google Flights via SerpAPI.
#
# How to get your free key:
#   1. Go to:   https://serpapi.com
#   2. Create a free account
#   3. Copy your API key from the dashboard
#   4. Paste it below (replacing "your_key_here")
#
# Free plan includes 100 searches/month — enough for a full season.
# ------------------------------------------------------------
SERPAPI_KEY=your_key_here
