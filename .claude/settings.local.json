{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python -c \"import sys,json; d=json.load(sys.stdin); exit(0 if 'git commit' in d.get('tool_input',{}).get('command','') else 1)\" && git push || true",
            "statusMessage": "Pushing to GitHub..."
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "WebSearch",
      "Bash(git:*)",
      "Bash(python:*)",
      "Bash(pip:*)",
      "Bash(ls:*)",
      "Bash(mv:*)",
      "Bash(rm:*)",
      "Bash(rmdir:*)",
      "Bash(mkdir:*)",
      "Bash(cp:*)",
      "Bash(grep:*)",
      "Bash(find:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(sed:*)",
      "Bash(echo:*)",
      "Bash(sleep:*)",
      "Bash(for:*)",
      "Bash(cmd.exe:*)",
      "Bash(powershell:*)",
      "Skill(update-config)",
      "Skill(update-config:*)"
    ],
    "deny": [
      "Read(.env)"
    ],
    "defaultMode": "bypassPermissions"
  }
}
